{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(grep *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git worktree add *)",
      "Bash(gh pr create *)",
      "Bash(todo *)",
      "Read(~/Todos/**)"
    ],
    "deny": [
      "Read(./.env)"
    ]
  }
}
